# ─── Servidor ───────────────────────────────────────────────────────
PORT=8000
NODE_ENV=production
RUN_MIGRATIONS=true

# ─── Postgres ───────────────────────────────────────────────────────
# No docker o host é "db"; local é "localhost". Use uma senha FORTE em prod.
DATABASE_URL=postgresql://stitchmind:CHANGE_ME@db:5432/stitchmind
DATABASE_POOL_SIZE=10

# ─── Redis (opcional, best-effort) ──────────────────────────────────
REDIS_URL=redis://cache:6379
REDIS_PREFIX=stitchmind:

# ─── Admin (painel) ─────────────────────────────────────────────────
# OBRIGATÓRIO em produção. Gere com: openssl rand -hex 32
ADMIN_JWT_SECRET=CHANGE_ME

# ─── MinIO / S3 (storage de mídia) ──────────────────────────────────
# No docker o endpoint é http://storage:9000. Use credenciais FORTES em prod.
S3_ENDPOINT=http://storage:9000
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_REGION=us-east-1
S3_BUCKET_UPLOADS=stitchmind-uploads
S3_BUCKET_PUBLIC=stitchmind-public
S3_PUBLIC_URL=https://stitchmindapp.com

# ─── Firebase Auth ──────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
# apiKey web (pública) p/ o login do painel via Firebase JS SDK.
FIREBASE_WEB_API_KEY=
# Service account (Admin SDK) p/ ENVIAR push via FCM: JSON inteiro OU caminho.
# FIREBASE_SERVICE_ACCOUNT=
# FIREBASE_SERVICE_ACCOUNT_PATH=/app/secrets/firebase-sa.json
# Em prod DEVE ser false (aceita tokens dev:<uid>:<email> quando true).
AUTH_DEV_MODE=false

# ─── IA ─────────────────────────────────────────────────────────────
# PROVIDER: "anthropic" ou "gemini" (vazio = auto-detecta pela key presente).
PROVIDER=
GEMINI_API_KEY=
GEMINI_MODEL_VISION=gemini-2.5-pro
GEMINI_MODEL_TEXT=gemini-2.5-flash-lite
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_PATTERN_MODEL=claude-opus-4-8
MAX_IMAGE_MB=8

# ─── Assinaturas (RevenueCat) ───────────────────────────────────────
# Secret API key (sk_...): verifica assinaturas server-side no /subscription/sync.
REVENUECAT_API_KEY=
# Header Authorization esperado do webhook (painel RC → Webhooks). Gere forte.
REVENUECAT_WEBHOOK_AUTH=
